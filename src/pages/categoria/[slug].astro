---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PageHero from '@components/PageHero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import BusinessCard from '@components/BusinessCard.astro';
import FeaturedBusiness from '@components/FeaturedBusiness.astro';
import CategorySidebar from '@components/CategorySidebar.astro';
import { site, getCategory, categories } from '@config/site';
import { breadcrumb, jsonLdScript, type JsonLd } from '@lib/seo';

export async function getStaticPaths() {
  const negocios = await getCollection('negocios');
  const migrated = [...new Set(negocios.map((e) => e.id.split('/')[0]))];
  return migrated
    .filter((slug) => categories.some((c) => c.slug === slug))
    .map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const cat = getCategory(slug!)!;
const negocios = await getCollection('negocios');
const list = negocios
  .filter((e) => e.id.split('/')[0] === slug)
  .sort((a, b) => a.data.order - b.data.order);

const url = `${site.url}/categoria/${slug}`;
const title = `Empresas de ${cat.name} en México | Directorio`;
const description = cat.description;

const jsonld: JsonLd[] = [
  breadcrumb([
    { name: 'Inicio', url: `${site.url}/` },
    { name: 'Categorías', url: `${site.url}/categorias` },
    { name: cat.name, url },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `Empresas de ${cat.name} en México`,
    numberOfItems: list.length,
    itemListElement: list.map((e, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: e.data.name,
      url: `${site.url}/negocios/${slug}/${e.id.split('/')[1]}`,
    })),
  },
];

const featuredList = list.filter((e) => e.data.featured);

const extraHead = `<script type="application/ld+json">${jsonLdScript(jsonld)}</script>`;
const registerMail = `mailto:${site.email}?subject=${encodeURIComponent(`Registrar mi empresa de ${cat.name} — Pamari`)}`;
---

<Layout
  title={title}
  description={description}
  canonical={url}
  ogTitle={`${cat.name} en México`}
  ogImage={cat.image ? `${site.url}${cat.image}` : undefined}
  extraHead={extraHead}
>

<Breadcrumbs items={[
    { label: 'Categorías', href: '/categorias' },
    { label: cat.name },
  ]} />

  <PageHero
    kicker="Categoría"
    titleHtml={cat.name.replace(/^(\S+)/, '<span class="highlight">$1</span>')}
    subtitle={cat.description}
  >
    <div class="page-hero-meta" slot="meta">
      <span class="chip chip-dark">{list.length} {list.length === 1 ? 'empresa verificada' : 'empresas verificadas'}</span>
      <span class="chip chip-dark">Cobertura nacional</span>
    </div>
  </PageHero>


  <section class="results-section">
    <div class="container">
      <div class="with-sidebar">

        <div class="main-col">
          <div class="section-head--split">
            <div>
              <span class="eyebrow">Empresas verificadas</span>
              <h2 class="section-title">Empresas de {cat.name}</h2>
              <div class="section-head-actions">
                <span class="results-count">{list.length} {list.length === 1 ? 'resultado' : 'resultados'} · datos confirmados</span>
              </div>
            </div>
            {cat.seoIntro && (
              <div class="section-seo-copy">
                <p>{cat.seoIntro[0]}</p>
                <p>{cat.seoIntro[1]}</p>
              </div>
            )}
          </div>

          <div class="category-grid-featured">
            {list.map((e) => <BusinessCard entry={e} />)}
          </div>

          {featuredList.map((e) => <FeaturedBusiness entry={e} />)}
        </div>

        <CategorySidebar current={slug!} />

      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="cta-band">
        <div>
          <h2>¿Tienes una empresa de {cat.name.toLowerCase()}?</h2>
          <p>Publica tu ficha verificada en Pamari y llega a más clientes.</p>
        </div>
        <a href={registerMail} class="btn btn-dark btn-lg">Registrar mi negocio</a>
      </div>
    </div>
  </section>
</Layout>

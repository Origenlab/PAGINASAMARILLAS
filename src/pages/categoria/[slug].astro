---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { site, getCategory, categories } from '@config/site';
import { breadcrumb, jsonLdScript, type JsonLd } from '@lib/seo';

export async function getStaticPaths() {
  const negocios = await getCollection('negocios');
  const migrated = [...new Set(negocios.map((e) => e.id.split('/')[0]))];
  return migrated
    .filter((slug) => categories.some((c) => c.slug === slug))
    .map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const cat = getCategory(slug!)!;
const negocios = await getCollection('negocios');
const list = negocios
  .filter((e) => e.id.split('/')[0] === slug)
  .sort((a, b) => a.data.order - b.data.order);

const url = `${site.url}/categoria/${slug}.html`;
const title = `${cat.name} en México — Empresas Verificadas | ${site.shortName}`;
const description = cat.description;

const jsonld: JsonLd[] = [
  breadcrumb([
    { name: 'Inicio', url: `${site.url}/` },
    { name: 'Categorías', url: `${site.url}/categorias` },
    { name: cat.name, url },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `Empresas de ${cat.name} en México`,
    numberOfItems: list.length,
    itemListElement: list.map((e, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: e.data.name,
      url: `${site.url}/negocios/${slug}/${e.id.split('/')[1]}.html`,
    })),
  },
];

const extraHead = `<script type="application/ld+json">${jsonLdScript(jsonld)}</script>`;
---

<Layout
  title={title}
  description={description}
  canonical={url}
  ogTitle={`${cat.name} en México`}
  ogImage={cat.image ? `${site.url}${cat.image}` : undefined}
  extraCss={['/css/categoria.css']}
  extraHead={extraHead}
>
  <nav class="breadcrumbs" aria-label="Ruta de navegación">
    <div class="container">
      <a href="/">Inicio</a>
      <span aria-hidden="true">›</span>
      <a href="/categorias">Categorías</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{cat.name}</span>
    </div>
  </nav>

  <section class="category-hero">
    <div class="container">
      <div class="category-header">
        <div class="category-info">
          <h1>{cat.name}</h1>
          <p>{cat.description}</p>
          <div class="category-stats">
            <span>{list.length} {list.length === 1 ? 'empresa verificada' : 'empresas verificadas'}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="results-section">
    <div class="container">
      <div class="results-header">
        <h2>{list.length} empresas de {cat.name}</h2>
      </div>

      <div class="business-listings">
        {list.map((e) => {
          const b = e.data;
          const bslug = e.id.split('/')[1];
          const href = `/negocios/${slug}/${bslug}.html`;
          return (
            <article class="business-card">
              <div class="business-image">
                <a href={href}>
                  <img src={b.image} alt={b.name} width="400" height="300" loading="lazy" />
                </a>
              </div>
              <div class="business-content">
                <div class="business-header">
                  <h3><a href={href}>{b.name}</a></h3>
                  {b.tagline && <p class="business-tagline">{b.tagline}</p>}
                </div>
                {b.services.length > 0 && (
                  <div class="business-services">
                    {b.services.slice(0, 4).map((s) => (
                      <span class="service-tag">{s.name}</span>
                    ))}
                  </div>
                )}
                <div class="business-details">
                  <div class="detail-item">
                    <strong>Ubicación:</strong> {b.address.locality}, {b.address.region}
                  </div>
                  {b.yearsExperience && (
                    <div class="detail-item">
                      <strong>Experiencia:</strong> {b.yearsExperience}+ años
                    </div>
                  )}
                </div>
                <div class="business-actions">
                  <a href={href} class="btn btn-primary">Ver perfil</a>
                  {b.phone && <a href={`tel:${b.phone}`} class="btn btn-outline">Llamar</a>}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="seo-content">
    <div class="container">
      <div class="seo-content-wrapper">
        <article class="seo-article">
          <h2>Empresas de {cat.name} en México</h2>
          <p>{cat.description}</p>
          <p>{cat.services}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="business-cta">
    <div class="container">
      <div class="cta-content">
        <h2>¿Tienes una empresa de {cat.name.toLowerCase()}?</h2>
        <p>Registra tu negocio en Páginas Amarillas México y llega a más clientes.</p>
        <a href="/#registrar" class="btn btn-primary">Registrar mi negocio</a>
      </div>
    </div>
  </section>
</Layout>

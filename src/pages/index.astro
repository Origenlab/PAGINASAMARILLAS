---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHero from '@components/PageHero.astro';
import UpcomingCategoryCard from '@components/UpcomingCategoryCard.astro';
import { site, categories, upcomingCategories } from '@config/site';
import { jsonLdScript, type JsonLd } from '@lib/seo';

const negocios = await getCollection('negocios');
const posts = await getCollection('blog', ({ data }) => !data.draft);

const countByCat = (slug: string) =>
  negocios.filter((e) => e.id.split('/')[0] === slug).length;

/* Curadas por `order`, no por fecha: ver la nota en src/content.config.ts */
const featuredPosts = posts
  .sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title))
  .slice(0, 3);

const jsonld: JsonLd[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    alternateName: 'Pamari México',
    url: `${site.url}/`,
    description: site.description,
    inLanguage: 'es-MX',
    publisher: {
      '@type': 'Organization',
      name: site.name,
      url: `${site.url}/`,
      email: site.email,
      telephone: site.phoneHref,
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: site.phoneHref,
        email: site.email,
        contactType: 'customer service',
        areaServed: 'MX',
        availableLanguage: 'Spanish',
      },
      sameAs: [site.social.facebook, site.social.instagram],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Categorías principales de negocios en México',
    numberOfItems: categories.length,
    itemListElement: categories.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.name,
      url: `${site.url}/categoria/${c.slug}`,
    })),
  },
];

const extraHead = `<script type="application/ld+json">${jsonLdScript(jsonld)}</script>`;
const registerMail = `mailto:${site.email}?subject=${encodeURIComponent('Quiero registrar mi negocio en Pamari')}`;
---

<Layout
  title="Directorio de Empresas en México | Negocios Verificados"
  description={site.description}
  canonical={`${site.url}/`}
  extraHead={extraHead}
>

  <PageHero
    kicker="Directorio empresarial de México"
    titleHtml='Encuentra negocios <span class="highlight">verificados</span> cerca de ti'
    subtitle="Empresas mexicanas con información real: servicios, teléfonos, cobertura y datos de contacto confirmados."
  />

  <!-- QUICK LINKS -->
  <nav class="quicklinks" aria-label="Accesos rápidos">
    <div class="container">
      <div class="quicklinks-grid">
        {categories.map((c) => (
          <a href={`/categoria/${c.slug}`} class="quicklink">
            <span class="quicklink-icon" aria-hidden="true">
              {c.icon === 'shield' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {c.icon === 'star' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              )}
              {c.icon === 'flame' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
              )}
            </span>
            <span class="quicklink-label">{c.name}</span>
            <span class="quicklink-arrow" aria-hidden="true">→</span>
          </a>
        ))}
        <a href="/categorias" class="quicklink">
          <span class="quicklink-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </span>
          <span class="quicklink-label">Todas las categorías</span>
          <span class="quicklink-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/blog/" class="quicklink">
          <span class="quicklink-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </span>
          <span class="quicklink-label">Blog y guías</span>
          <span class="quicklink-arrow" aria-hidden="true">→</span>
        </a>
        <a href={registerMail} class="quicklink quicklink-cta">
          <span class="quicklink-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
          </span>
          <span class="quicklink-label">Registrar mi negocio</span>
          <span class="quicklink-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- CATEGORÍAS -->
  <section class="section" id="categorias">
    <div class="container">
      <div class="section-head--split">
        <div>
          <span class="eyebrow">Explora el directorio</span>
          <h2 class="section-title">Categorías principales</h2>
          <div class="section-head-actions">
            <a href="/categorias" class="btn btn-outline">Ver todas las categorías</a>
          </div>
        </div>
        <div class="section-seo-copy">
          <p>
            <strong>Empresas en México</strong> verificadas y organizadas por categoría: seguridad privada, entretenimiento para eventos y equipos contra incendios. Cada ficha del directorio incluye servicios, cobertura, horarios y datos de contacto confirmados directamente con el negocio, para que encuentres un proveedor confiable sin perder tiempo.
          </p>
          <p>
            A diferencia de otros directorios de negocios, en Pamari no hay listados basura ni empresas fantasma: revisamos teléfono, domicilio y servicios antes de publicar. Explora la categoría que necesitas y contacta directo, sin registros ni intermediarios.
          </p>
        </div>
      </div>

      <div class="category-grid-featured">
        {categories.map((cat) => {
          const count = countByCat(cat.slug);
          return (
            <a href={`/categoria/${cat.slug}`} class="category-card-featured">
              <div class="category-card-image" class:list={[!cat.image && 'category-card-placeholder']} style={!cat.image ? 'background: linear-gradient(135deg, #26262E 0%, #101014 100%);' : undefined}>
                {cat.image ? (
                  <img src={cat.image} alt={`Empresas de ${cat.name} en México`} loading="lazy" width="400" height="225" />
                ) : (
                  <div class="category-placeholder-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#FFC700" stroke-width="1.5" aria-hidden="true">
                      <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
                    </svg>
                  </div>
                )}
                <div class="category-card-overlay"></div>
                <span class="category-card-count-badge">{count} {count === 1 ? 'empresa' : 'empresas'}</span>
              </div>
              <div class="category-card-content">
                <h3 class="category-card-title">{cat.name}</h3>
                <p class="category-card-description">{cat.description}</p>
                <p class="category-card-services">{cat.services}</p>
                <div class="category-card-meta">
                  <span class="category-card-count">Datos verificados</span>
                  <span class="category-card-arrow">Explorar <span aria-hidden="true">→</span></span>
                </div>
              </div>
            </a>
          );
        })}

        <a href={registerMail} class="category-card-featured category-card-register">
          <div class="category-card-register-inner">
            <span class="category-card-register-plus" aria-hidden="true">+</span>
            <h3 class="category-card-title">Tu categoría aquí</h3>
            <p class="category-card-description">
              ¿Tu giro aún no está en el directorio? Regístralo y sé de las primeras empresas listadas cuando abramos tu categoría.
            </p>
            <span class="category-card-arrow">Registrar mi negocio <span aria-hidden="true">→</span></span>
          </div>
        </a>
      </div>

      <div class="upcoming-block">
        <span class="eyebrow">Próximas categorías · según demanda en México</span>
        <div class="category-grid-featured" style="margin-top: 1.5rem;">
          {upcomingCategories.map((cat) => (
            <UpcomingCategoryCard category={cat} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG DESTACADO -->
  {featuredPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head--split">
          <div>
            <span class="eyebrow">Del blog</span>
            <h2 class="section-title">Guías destacadas</h2>
            <div class="section-head-actions">
              <a href="/blog/" class="btn btn-outline">Ver el blog</a>
            </div>
          </div>
          <div class="section-seo-copy">
            <p>
              Contenido editorial que responde lo que la gente realmente pregunta antes de contratar: cuánto cuesta la seguridad privada en CDMX, qué certificaciones exigir, cómo elegir proveedor de eventos o qué extintor necesita tu negocio según la NOM-002-STPS.
            </p>
            <p>
              Cada guía enlaza con <strong>empresas verificadas del directorio</strong>, para que pases de investigar a cotizar en un solo paso.
            </p>
          </div>
        </div>
        <div class="blog-grid">
          {featuredPosts.map((entry) => {
            const [categoria, slug] = entry.id.split('/');
            const href = `/blog/${categoria}/${slug}`;
            const d = entry.data;
            return (
              <article class="blog-card">
                {d.image && (
                  <a href={href} class="blog-card-image" aria-label={d.title}>
                    <img src={d.image} alt={d.title} width="400" height="225" loading="lazy" />
                  </a>
                )}
                <div class="blog-card-body">
                  <span class="blog-card-category">{d.categoryName}</span>
                  <h3><a href={href}>{d.title}</a></h3>
                  <p>{d.description}</p>
                  <a href={href} class="blog-card-link">Leer más →</a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- CTA REGISTRO -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="cta-band">
        <div>
          <h2>¿Tienes un negocio en México?</h2>
          <p>Publica tu empresa con ficha completa, posicionamiento en Google y contacto directo con clientes.</p>
        </div>
        <a href={registerMail} class="btn btn-dark btn-lg">Registrar mi negocio</a>
      </div>
    </div>
  </section>

</Layout>

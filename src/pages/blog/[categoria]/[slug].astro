---
import { getCollection, render } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { site } from '@config/site';
import { article, breadcrumb, jsonLdScript, type JsonLd } from '@lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((entry) => {
    const [categoria, slug] = entry.id.split('/');
    return { params: { categoria, slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const p = entry.data;
const { Content } = await render(entry);

const [categoria, slug] = entry.id.split('/');
const url = `${site.url}/blog/${categoria}/${slug}.html`;
const ogImage = p.image
  ? p.image.startsWith('http')
    ? p.image
    : `${site.url}${p.image}`
  : undefined;
const iso = (d?: Date) => (d ? d.toISOString().slice(0, 10) : undefined);

const jsonld: JsonLd[] = [
  article({
    title: p.title,
    description: p.description,
    url,
    image: ogImage,
    author: p.author,
    datePublished: iso(p.publishDate),
    dateModified: iso(p.updatedDate),
  }),
  breadcrumb([
    { name: 'Inicio', url: `${site.url}/` },
    { name: 'Blog', url: `${site.url}/blog/` },
    { name: p.title, url },
  ]),
];

const keywords = p.keywords.join(', ');
const extraHead = [
  keywords ? `<meta name="keywords" content="${keywords}">` : '',
  `<script type="application/ld+json">${jsonLdScript(jsonld)}</script>`,
].join('\n');
---

<Layout
  title={`${p.title} | ${site.shortName}`}
  description={p.description}
  canonical={url}
  ogTitle={p.title}
  ogType="article"
  ogImage={ogImage}
  extraCss={['/css/blog-article.css']}
  extraHead={extraHead}
>
  <article class="blog-article">
    <div class="container article-container">
      <nav class="breadcrumbs" aria-label="Ruta de navegación">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{p.categoryName}</span>
      </nav>

      <header class="article-header">
        <span class="article-category">{p.categoryName}</span>
        <h1>{p.title}</h1>
        <p class="article-lead">{p.description}</p>
        {p.publishDate && (
          <time datetime={iso(p.publishDate)}>
            {p.publishDate.toLocaleDateString('es-MX', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
      </header>

      {p.image && (
        <img class="article-hero" src={p.image} alt={p.title} width="1200" height="630" />
      )}

      <div class="article-content">
        <Content />
      </div>

      <footer class="article-footer">
        <a href="/blog/" class="btn btn-outline">← Volver al blog</a>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .article-container {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  .breadcrumbs {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .breadcrumbs a { color: var(--color-gray-600); }
  .article-header { margin-bottom: 1.5rem; }
  .article-category {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-secondary);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    margin-bottom: 1rem;
  }
  .article-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.2;
    color: var(--color-gray-900);
    margin-bottom: 0.75rem;
  }
  .article-lead {
    font-size: 1.15rem;
    color: var(--color-gray-600);
    line-height: 1.6;
  }
  .article-header time {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-gray-500);
  }
  .article-hero {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: 1.5rem 0 2rem;
  }
  .article-content { font-size: 1.05rem; line-height: 1.8; color: var(--color-gray-800); }
  .article-content :global(h2) { font-size: 1.6rem; margin: 2rem 0 1rem; color: var(--color-gray-900); }
  .article-content :global(h3) { font-size: 1.25rem; margin: 1.5rem 0 0.75rem; color: var(--color-gray-900); }
  .article-content :global(p) { margin-bottom: 1.1rem; }
  .article-content :global(ul),
  .article-content :global(ol) { margin: 0 0 1.1rem 1.25rem; }
  .article-content :global(li) { margin-bottom: 0.5rem; }
  .article-content :global(a) { color: var(--color-primary-dark); text-decoration: underline; }
  .article-content :global(img) { max-width: 100%; height: auto; border-radius: var(--radius-md); margin: 1rem 0; }
  .article-footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-gray-200); }
</style>

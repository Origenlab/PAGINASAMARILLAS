---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';

const NOMBRE_CAT: Record<string, string> = {
  'seguridad-privada': 'Seguridad Privada',
  eventos: 'Eventos',
};

const DESCRIPCION: Record<string, string> = {
  'seguridad-privada':
    'Artículos sobre seguridad privada, vigilancia, certificaciones CNSP y protección para empresas, condominios y eventos en México.',
  eventos:
    'Artículos sobre iluminación, audio, mobiliario y producción para eventos, bodas y fiestas en CDMX.',
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const cats = [...new Set(posts.map((p) => p.data.categoria))];
  return cats.map((slug) => ({
    params: { slug },
    props: { posts: posts.filter((p) => p.data.categoria === slug) },
  }));
}

const { slug } = Astro.params;
const { posts } = Astro.props;

const nombre = NOMBRE_CAT[slug!] ?? slug!;
const descripcion = DESCRIPCION[slug!] ?? `Artículos sobre ${nombre}.`;

const ordenados = [...posts].sort(
  (a, b) => (b.data.publicado?.getTime() ?? 0) - (a.data.publicado?.getTime() ?? 0)
);

const SITE = 'https://paginasamarillas.mx';
const url = `${SITE}/blog/categorias/${slug}`;
---

<Layout
  title={`${nombre} | Blog | Páginas Amarillas México`}
  description={descripcion}
  canonical={url}
  extraCss={['/css/blog-article.css']}
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: `${nombre} — Blog`,
      description: descripcion,
      url,
      inLanguage: 'es-MX',
      mainEntity: {
        '@type': 'ItemList',
        numberOfItems: ordenados.length,
        itemListElement: ordenados.map((p, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          url: `${SITE}/blog/${p.id.split('/')[0]}/${p.id.split('/')[1]}`,
          name: p.data.titulo,
        })),
      },
    })}
  />

  <section class="breadcrumbs">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
          <li><a href="/">Inicio</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li aria-current="page">{nombre}</li>
        </ol>
      </nav>
    </div>
  </section>

  <section class="blog-header">
    <div class="container">
      <h1 class="blog-title">{nombre}</h1>
      <p class="blog-subtitle">{descripcion}</p>
    </div>
  </section>

  <section class="blog-section">
    <div class="container">
      <div class="blog-layout">
        <div class="blog-main">
          <p class="blog-count">
            <span id="blog-count">{ordenados.length}</span>
            {ordenados.length === 1 ? ' artículo' : ' artículos'}
          </p>

          <div class="blog-grid" id="blog-grid">
            {ordenados.map((post) => <BlogCard post={post} />)}
          </div>

          <p class="results-empty" id="blog-empty" hidden>
            Ningún artículo coincide con esa búsqueda.
          </p>
        </div>

        <BlogSidebar categoriaActiva={slug} />
      </div>
    </div>
  </section>

  <script>
    const grid = document.querySelector<HTMLElement>('#blog-grid');
    const input = document.querySelector<HTMLInputElement>('#blog-q');
    const cuenta = document.querySelector<HTMLElement>('#blog-count');
    const vacio = document.querySelector<HTMLElement>('#blog-empty');

    if (grid && input) {
      const cards = [...grid.querySelectorAll<HTMLElement>('.blog-card')];
      const textos = cards.map((c) => (c.textContent ?? '').toLowerCase());

      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let visibles = 0;
        cards.forEach((c, i) => {
          const ok = !q || textos[i].includes(q);
          c.hidden = !ok;
          if (ok) visibles++;
        });
        if (cuenta) cuenta.textContent = String(visibles);
        if (vacio) vacio.hidden = visibles > 0;
      });
    }
  </script>
</Layout>

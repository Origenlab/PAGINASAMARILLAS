---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHero from '@components/PageHero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { site, categories } from '@config/site';
import { breadcrumb, jsonLdScript } from '@lib/seo';

const negocios = await getCollection('negocios');
const posts = await getCollection('blog', ({ data }) => !data.draft);

const byCat = (slug: string) =>
  negocios
    .filter((e) => e.id.split('/')[0] === slug)
    .sort((a, b) => a.data.order - b.data.order);

const blogCats = [...new Set(posts.map((p) => p.id.split('/')[0]))].map((slug) => ({
  slug,
  name: posts.find((p) => p.id.split('/')[0] === slug)!.data.categoryName,
  posts: posts.filter((p) => p.id.split('/')[0] === slug),
}));

const extraHead = `<script type="application/ld+json">${jsonLdScript(
  breadcrumb([
    { name: 'Inicio', url: `${site.url}/` },
    { name: 'Mapa del Sitio', url: `${site.url}/sitemap` },
  ]),
)}</script>`;
---

<Layout
  title="Mapa del Sitio — Pamari"
  description="Mapa completo del sitio de Pamari: categorías, empresas verificadas y artículos del blog."
  canonical={`${site.url}/sitemap`}
  extraHead={extraHead}
>

<Breadcrumbs items={[{ label: 'Mapa del sitio' }]} />

  <PageHero
    kicker="Navegación"
    titleHtml='Mapa del <span class="highlight">sitio</span>'
    subtitle="Todas las secciones, categorías y empresas del directorio en un solo lugar."
  />


  <section class="sitemap-page">
    <div class="container">
      <div class="sitemap-grid">

        <div class="sitemap-section">
          <h2>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Páginas principales
          </h2>
          <ul class="sitemap-links">
            <li><a href="/">Inicio</a></li>
            <li><a href="/categorias">Categorías</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/sitemap">Mapa del sitio</a></li>
          </ul>
        </div>

        {categories.map((cat) => {
          const list = byCat(cat.slug);
          return (
            <div class="sitemap-section">
              <h2>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {cat.name}
              </h2>
              <ul class="sitemap-links">
                <li><a href={`/categoria/${cat.slug}`}>Ver categoría</a></li>
              </ul>
              {list.length > 0 && (
                <div class="sitemap-subsection">
                  <h3>Empresas listadas</h3>
                  <ul class="sitemap-links">
                    {list.map((e) => (
                      <li>
                        <a href={`/negocios/${cat.slug}/${e.id.split('/')[1]}`}>{e.data.name}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          );
        })}

        {blogCats.map((bc) => (
          <div class="sitemap-section">
            <h2>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              Blog · {bc.name}
            </h2>
            <ul class="sitemap-links">
              <li><a href={`/blog/categorias/${bc.slug}`}>Ver todos los artículos</a></li>
              {bc.posts.slice(0, 12).map((p) => (
                <li>
                  <a href={`/blog/${bc.slug}/${p.id.split('/')[1]}`}>{p.data.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Todas las Categorías - Páginas Amarillas México"
  description="Explora todas las categorías de negocios en México. Encuentra empresas de seguridad, restaurantes, hoteles, salud, automotriz y más en todo el país."
  canonical="https://paginasamarillas.mx/categorias"
  extraCss={["/css/categoria.css"]}
  extraHead={`
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Categorías de Negocios",
    "description": "Directorio completo de categorías de negocios y servicios en México",
    "url": "https://paginasamarillas.mx/categorias",
    "inLanguage": "es-MX",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Páginas Amarillas México",
      "url": "https://paginasamarillas.mx/"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://paginasamarillas.mx/" },
      { "@type": "ListItem", "position": 2, "name": "Categorías", "item": "https://paginasamarillas.mx/categorias" }
    ]
  }
  </script>
  `}
>

  <section class="breadcrumbs">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
          <li><a href="/">Inicio</a></li>
          <li aria-current="page">Categorías</li>
        </ol>
      </nav>
    </div>
  </section>

  <section class="page-header">
    <div class="container">
      <h1 class="page-title">Todas las Categorías</h1>
      <p class="page-subtitle">Explora negocios y servicios organizados por categoría en todo México</p>
    </div>
  </section>

  <section class="categories-listing" id="categorias">
    <div class="container">

      <div class="category-search-box">
        <div class="search-field">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M14 14l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input type="text" id="categorySearch" placeholder="Buscar categoría..." aria-label="Buscar categoría">
        </div>
      </div>

      <h2 class="section-subtitle" style="margin-bottom: var(--spacing-lg); font-size: var(--font-size-lg); color: var(--color-gray-600);">Categorías Activas</h2>

      <div class="category-grid-featured">

        <a href="/categoria/seguridad-privada.html" class="category-card-featured">
          <div class="category-card-image">
            <img src="/img/img-seguridad-privada/equipo-seguridad-corporativo.webp" alt="Empresas de Seguridad Privada en México" loading="lazy" width="400" height="300">
            <div class="category-card-overlay"></div>
          </div>
          <div class="category-card-content">
            <div class="category-card-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="category-card-title">Seguridad Privada</h3>
            <p class="category-card-description">Empresas certificadas de vigilancia, guardias de seguridad, escoltas ejecutivos y protección empresarial en todo México.</p>
            <p class="category-card-services">Guardias armados y sin armar, monitoreo 24/7, seguridad para eventos, condominios, corporativos e industrial.</p>
            <div class="category-card-meta">
              <span class="category-card-count">4 empresas verificadas</span>
              <span class="category-card-rating">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.8
              </span>
            </div>
          </div>
        </a>

        <a href="/categoria/entretenimiento.html" class="category-card-featured">
          <div class="category-card-image">
            <img src="/img/img-eventos/decoracion-fiesta-luces.webp" alt="Entretenimiento y Eventos en México" loading="lazy" width="400" height="300">
            <div class="category-card-overlay"></div>
          </div>
          <div class="category-card-content">
            <div class="category-card-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <h3 class="category-card-title">Entretenimiento y Eventos</h3>
            <p class="category-card-description">Las mejores empresas de entretenimiento para fiestas infantiles, eventos corporativos, bodas y celebraciones en México.</p>
            <p class="category-card-services">Inflables, brincolines, shows de luces, DJ, sonido, animadores, payasos, magos y decoración para eventos.</p>
            <div class="category-card-meta">
              <span class="category-card-count">7 empresas verificadas</span>
              <span class="category-card-rating">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.8
              </span>
            </div>
          </div>
        </a>

        <a href="/categoria/equipos-contra-incendios.html" class="category-card-featured">
          <div class="category-card-image category-card-placeholder" style="background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);">
            <div class="category-placeholder-icon">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
            </div>
            <div class="category-card-overlay"></div>
          </div>
          <div class="category-card-content">
            <div class="category-card-badge" style="background: rgba(220, 38, 38, 0.9);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
            </div>
            <h3 class="category-card-title">Equipos Contra Incendios</h3>
            <p class="category-card-description">Proveedores certificados de extintores, sistemas contra incendios, detectores de humo y equipos de protección en México.</p>
            <p class="category-card-services">Extintores CO2, PQS, agua, sistemas automáticos, gabinetes, mangueras, señalización y capacitación NOM-002-STPS.</p>
            <div class="category-card-meta">
              <span class="category-card-count">5 empresas verificadas</span>
              <span class="category-card-rating">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                4.8
              </span>
            </div>
          </div>
        </a>

      </div>

      <h2 class="section-subtitle" style="margin: var(--spacing-2xl) 0 var(--spacing-lg); font-size: var(--font-size-lg); color: var(--color-gray-600);">Próximamente</h2>

      <div class="category-grid">
        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2M7 2v20M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
          </div>
          <h3 class="category-name">Restaurantes</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Comida mexicana, internacional, cafeterías, bares, mariscos, taquerías y gastronomía de todo tipo</p>
        </div>

        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10h18M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/></svg>
          </div>
          <h3 class="category-name">Hoteles y Hospedaje</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Hoteles 5 estrellas, boutique, moteles, hostales, Airbnb y alojamiento turístico</p>
        </div>

        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="category-name">Salud y Medicina</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Médicos especialistas, hospitales, clínicas, farmacias, dentistas y laboratorios</p>
        </div>

        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 17h2v-6H5a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2zm14 0h-2v-6h2a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2zM7 17v4m10-4v4M5 11V6a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v5"/></svg>
          </div>
          <h3 class="category-name">Automotriz</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Mecánicos certificados, refaccionarias, talleres de hojalatería, agencias y autopartes</p>
        </div>

        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <h3 class="category-name">Educación</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Escuelas primarias, secundarias, preparatorias, universidades, cursos y capacitación empresarial</p>
        </div>

        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3 class="category-name">Construcción</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Constructoras, arquitectos, ingenieros civiles, materiales de construcción y remodelaciones</p>
        </div>

        <div class="category-card category-card-disabled">
          <div class="category-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="category-name">Tecnología</h3>
          <span class="category-badge">Próximamente</span>
          <p class="category-description">Desarrollo de software, reparación de computadoras, redes, ciberseguridad y consultoría TI</p>
        </div>
      </div>

      <div class="info-box">
        <h3>¿No encuentras lo que buscas?</h3>
        <p>Estamos trabajando para agregar más categorías constantemente. Si tienes una sugerencia, <a href="#contacto">contáctanos</a>.</p>
      </div>

    </div>
  </section>

</Layout>

<script>
  document.getElementById('categorySearch')?.addEventListener('input', function(e) {
    const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
    const featuredCards = document.querySelectorAll('.category-card-featured');
    const regularCards = document.querySelectorAll('.category-card');

    featuredCards.forEach(card => {
      const el = card as HTMLElement;
      const name = el.querySelector('.category-card-title')?.textContent?.toLowerCase() || '';
      const desc = el.querySelector('.category-card-description')?.textContent?.toLowerCase() || '';
      const services = el.querySelector('.category-card-services')?.textContent?.toLowerCase() || '';
      el.style.display = (name.includes(searchTerm) || desc.includes(searchTerm) || services.includes(searchTerm)) ? '' : 'none';
    });

    regularCards.forEach(card => {
      const el = card as HTMLElement;
      const name = el.querySelector('.category-name')?.textContent?.toLowerCase() || '';
      const desc = el.querySelector('.category-description')?.textContent?.toLowerCase() || '';
      el.style.display = (name.includes(searchTerm) || desc.includes(searchTerm)) ? '' : 'none';
    });
  });
</script>

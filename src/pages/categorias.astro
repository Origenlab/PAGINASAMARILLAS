---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHero from '@components/PageHero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import UpcomingCategoryCard from '@components/UpcomingCategoryCard.astro';
import { site, categories, upcomingCategories } from '@config/site';
import { breadcrumb, jsonLdScript, type JsonLd } from '@lib/seo';

const negocios = await getCollection('negocios');
const countByCat = (slug: string) =>
  negocios.filter((e) => e.id.split('/')[0] === slug).length;

const jsonld: JsonLd[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Categorías de Negocios',
    description: 'Directorio completo de categorías de negocios y servicios en México',
    url: `${site.url}/categorias`,
    inLanguage: 'es-MX',
    isPartOf: { '@type': 'WebSite', name: site.name, url: `${site.url}/` },
  },
  breadcrumb([
    { name: 'Inicio', url: `${site.url}/` },
    { name: 'Categorías', url: `${site.url}/categorias` },
  ]),
];

const extraHead = `<script type="application/ld+json">${jsonLdScript(jsonld)}</script>`;
const registerMail = `mailto:${site.email}?subject=${encodeURIComponent('Sugerencia de categoría — Pamari')}`;
---

<Layout
  title="Todas las Categorías — Pamari"
  description="Explora todas las categorías de negocios verificados en México: seguridad privada, entretenimiento, equipos contra incendios y más."
  canonical={`${site.url}/categorias`}
  extraHead={extraHead}
>

<Breadcrumbs items={[{ label: 'Categorías' }]} />

  <PageHero
    kicker="Directorio"
    titleHtml='Todas las <span class="highlight">categorías</span>'
    subtitle="Negocios y servicios verificados, organizados por sector en todo México."
  />


  <section class="section" style="padding-top: 1rem;">
    <div class="container">

      <div class="category-search-box">
        <div class="search-field">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M14 14l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input type="text" id="categorySearch" placeholder="Filtrar categorías…" aria-label="Filtrar categorías">
        </div>
      </div>

      <span class="eyebrow">Activas</span>
      <div class="category-grid-featured" style="margin-top: 1rem;">
        {categories.map((cat) => {
          const count = countByCat(cat.slug);
          return (
            <a href={`/categoria/${cat.slug}`} class="category-card-featured">
              <div class="category-card-image" class:list={[!cat.image && 'category-card-placeholder']} style={!cat.image ? 'background: linear-gradient(135deg, #26262E 0%, #101014 100%);' : undefined}>
                {cat.image ? (
                  <img src={cat.image} alt={`Empresas de ${cat.name} en México`} loading="lazy" width="400" height="225" />
                ) : (
                  <div class="category-placeholder-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#FFC700" stroke-width="1.5" aria-hidden="true">
                      <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
                    </svg>
                  </div>
                )}
                <div class="category-card-overlay"></div>
                <span class="category-card-count-badge">{count} {count === 1 ? 'empresa' : 'empresas'}</span>
              </div>
              <div class="category-card-content">
                <h3 class="category-card-title">{cat.name}</h3>
                <p class="category-card-description">{cat.description}</p>
                <p class="category-card-services">{cat.services}</p>
                <div class="category-card-meta">
                  <span class="category-card-count">Datos verificados</span>
                  <span class="category-card-arrow">Explorar <span aria-hidden="true">→</span></span>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <span class="eyebrow" style="margin-top: 3.5rem;">Próximamente · priorizadas por demanda en México</span>
      <div class="category-grid-featured" style="margin-top: 1rem;">
        {upcomingCategories.map((cat) => (
          <UpcomingCategoryCard category={cat} />
        ))}
      </div>

      <div class="info-box">
        <h3>¿No encuentras lo que buscas?</h3>
        <p>Agregamos categorías nuevas constantemente. Si tienes una sugerencia, <a href={registerMail}>escríbenos</a>.</p>
      </div>

    </div>
  </section>

</Layout>

<script is:inline>
  document.getElementById('categorySearch')?.addEventListener('input', function (e) {
    var q = e.target.value.toLowerCase();
    document.querySelectorAll('.category-card-featured, .category-card').forEach(function (el) {
      el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>

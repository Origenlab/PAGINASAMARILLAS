---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Página no encontrada - Páginas Amarillas México"
  description="La página que buscas no existe. Regresa al inicio de Páginas Amarillas México."
  canonical="https://paginasamarillas.mx/404"
>
  <section style="text-align:center;padding:6rem 2rem;">
    <div class="container">
      <h1 style="font-size:4rem;color:var(--color-primary);margin-bottom:1rem;">404</h1>
      <h2 style="font-size:1.5rem;color:var(--color-gray-900);margin-bottom:1rem;">Página no encontrada</h2>
      <p style="color:var(--color-gray-600);margin-bottom:2rem;">Lo sentimos, la página que buscas no existe o ha sido movida.</p>
      <a href="/" class="btn btn-primary">Ir al Inicio</a>
    </div>
  </section>
</Layout>

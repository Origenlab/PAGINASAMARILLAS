---
import Layout from '../layouts/Layout.astro';
import { site } from '@config/site';
---

<Layout
  title="Página no encontrada — Pamari"
  description="La página que buscas no existe. Regresa al inicio de Pamari."
  canonical={`${site.url}/404`}
>
  <section class="error-page">
    <div class="container">
      <div class="error-code">404</div>
      <h2>Página no encontrada</h2>
      <p>La página que buscas no existe o fue movida. Prueba desde el inicio o explora las categorías del directorio.</p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary btn-lg">Ir al inicio</a>
        <a href="/categorias" class="btn btn-outline btn-lg">Ver categorías</a>
      </div>
    </div>
  </section>
</Layout>

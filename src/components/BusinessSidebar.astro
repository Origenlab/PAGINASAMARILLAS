---
/**
 * Sidebar de la ficha de negocio — widgets de conversión e interlinking:
 * contacto rápido (sticky), más empresas de la categoría, guías del blog
 * y navegación del directorio.
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { site, categories, getCategory } from '@config/site';

interface Props {
  entry: CollectionEntry<'negocios'>;
}

const { entry } = Astro.props;
const n = entry.data;
const [categoria, slug] = entry.id.split('/');
const cat = getCategory(categoria);
const blogSlug = cat?.blogSlug ?? categoria;

const negocios = await getCollection('negocios');
const sameCat = negocios
  .filter((e) => e.id.split('/')[0] === categoria && e.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((p) => p.id.split('/')[0] === blogSlug)
  .sort((a, b) => {
    /* Primero las guías relacionadas con esta empresa (id completo, no slug) */
    const relA = a.data.relatedBusiness?.id === entry.id ? 1 : 0;
    const relB = b.data.relatedBusiness?.id === entry.id ? 1 : 0;
    if (relA !== relB) return relB - relA;
    return a.data.order - b.data.order || a.data.title.localeCompare(b.data.title);
  })
  .slice(0, 5);

const countByCat = (s: string) => negocios.filter((e) => e.id.split('/')[0] === s).length;
const wa = n.whatsapp ? `https://wa.me/52${n.whatsapp.replace(/\D/g, '')}` : null;
---

<aside class="sidebar" aria-label="Contacto y contenido relacionado">

  <!-- Contacto rápido -->
  <div class="widget widget-contact">
    <h3 class="widget-title">Contacto directo</h3>
    <div class="wc-actions">
      {n.phone && (
        <a href={`tel:${n.phone}`} class="btn btn-primary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {n.phoneDisplay ?? 'Llamar'}
        </a>
      )}
      {wa && (
        <a href={wa} class="btn btn-outline fb-btn-wa" rel="nofollow noopener" target="_blank">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      )}
    </div>
    {n.hoursDisplay.length > 0 && (
      <ul class="wc-hours">
        {n.hoursDisplay.slice(0, 3).map((h) => <li>{h}</li>)}
      </ul>
    )}
  </div>

  {sameCat.length > 0 && (
    <div class="widget">
      <h3 class="widget-title">Más de {n.categoryName}</h3>
      <ul class="widget-business">
        {sameCat.map((e) => {
          const [cslug, bslug] = e.id.split('/');
          return (
            <li>
              <a href={`/negocios/${cslug}/${bslug}`}>
                <img src={e.data.image} alt={e.data.name} width="56" height="42" loading="lazy" />
                <span class="wb-info">
                  <span class="wb-name">{e.data.name}</span>
                  <span class="wb-cat">{e.data.address.locality}</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
      <a href={`/categoria/${categoria}`} class="widget-more">Ver toda la categoría →</a>
    </div>
  )}

  {posts.length > 0 && (
    <div class="widget">
      <h3 class="widget-title">Guías de {n.categoryName}</h3>
      <ul class="widget-links">
        {posts.map((p) => (
          <li>
            <a href={`/blog/${blogSlug}/${p.id.split('/')[1]}`}>{p.data.title}</a>
          </li>
        ))}
      </ul>
      <a href={`/blog/categorias/${blogSlug}`} class="widget-more">Ver todas las guías →</a>
    </div>
  )}

  <div class="widget">
    <h3 class="widget-title">Explora el directorio</h3>
    <ul class="widget-links widget-links-cats">
      {categories.map((c) => (
        <li>
          <a href={`/categoria/${c.slug}`}>
            <span>{c.name}</span>
            <span class="widget-count">{countByCat(c.slug)}</span>
          </a>
        </li>
      ))}
      <li><a href="/categorias"><span>Todas las categorías</span></a></li>
      <li><a href="/blog/"><span>Blog y guías</span></a></li>
      <li><a href="/sitemap"><span>Mapa del sitio</span></a></li>
    </ul>
  </div>

  <div class="widget widget-cta">
    <h3>¿Tienes un negocio?</h3>
    <p>Publica tu ficha verificada como esta y aparece donde te buscan.</p>
    <a href={`mailto:${site.email}?subject=${encodeURIComponent('Quiero registrar mi negocio en Pamari')}`} class="btn btn-primary">Registrar mi negocio</a>
  </div>

</aside>

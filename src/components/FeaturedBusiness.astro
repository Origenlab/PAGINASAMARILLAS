---
/**
 * Módulo "Empresa destacada" — card de 2 columnas:
 * izquierda: resumen completo de la empresa (justificado y ordenado),
 * derecha: mini galería (1 imagen grande + 2 chicas).
 * Renderiza solo la card; el layout padre decide el contenedor.
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'negocios'>;
}

const { entry } = Astro.props;
const b = entry.data;
const [categoria, slug] = entry.id.split('/');
const href = `/negocios/${categoria}/${slug}`;

/* Galería: frontmatter o fallback a la imagen principal */
const gallery = b.gallery.length >= 3 ? b.gallery.slice(0, 3) : [b.image, b.image, b.image];

const wa = b.whatsapp ? `https://wa.me/52${b.whatsapp.replace(/\D/g, '')}` : null;
const websiteLabel = b.website?.replace(/^https?:\/\//, '').replace(/\/$/, '');
---

<div class="featured-business-card">

  <!-- Col 1: resumen de la empresa -->
  <div class="fb-info">
    <span class="eyebrow">Empresa destacada</span>
    <h2 class="fb-name"><a href={href}>{b.name}</a></h2>
    {b.slogan && <p class="fb-slogan">“{b.slogan}”</p>}

    <p class="fb-description">{b.summary ?? b.description.replace(/^➤\s*/, '').replace(/\s*☎.*$/, '')}</p>

    <div class="fb-facts">
      <div class="fb-fact">
        <strong>Ubicación</strong>
        <span>{b.address.locality}, {b.address.region}</span>
      </div>
      {b.yearsExperience && (
        <div class="fb-fact">
          <strong>Experiencia</strong>
          <span>{b.yearsExperience}+ años</span>
        </div>
      )}
      {b.employees && (
        <div class="fb-fact">
          <strong>Personal</strong>
          <span>{b.employees}+ elementos</span>
        </div>
      )}
      {b.areaServed.length > 0 && (
        <div class="fb-fact">
          <strong>Cobertura</strong>
          <span>{b.areaServed.slice(0, 2).join(', ')}{b.areaServed.length > 2 ? ` +${b.areaServed.length - 2}` : ''}</span>
        </div>
      )}
    </div>

    {b.whyUs.length > 0 && (
      <ul class="benefits-list fb-benefits">
        {b.whyUs.slice(0, 3).map((w) => <li>{w}</li>)}
      </ul>
    )}

    <div class="fb-actions">
      <a href={href} class="btn btn-primary">
        Ver perfil
      </a>
      {b.phone && (
        <a href={`tel:${b.phone}`} class="btn btn-outline">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Llamar
        </a>
      )}
      {wa && (
        <a href={wa} class="btn btn-outline fb-btn-wa" rel="nofollow noopener" target="_blank">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      )}
      {b.website && (
        <a href={b.website} class="btn btn-outline" rel="nofollow noopener" target="_blank" title={websiteLabel}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Sitio oficial
        </a>
      )}
    </div>
  </div>

  <!-- Col 2: mini galería -->
  <div class="fb-gallery">
    <a href={href} class="fb-gallery-main" aria-label={`Galería de ${b.name}`}>
      <img src={gallery[0]} alt={`${b.name} — imagen principal`} width="640" height="400" loading="lazy" />
    </a>
    <a href={href} class="fb-gallery-thumb" aria-label={`Ver perfil de ${b.name}`}>
      <img src={gallery[1]} alt={`${b.name} — galería 2`} width="320" height="200" loading="lazy" />
    </a>
    <a href={href} class="fb-gallery-thumb" aria-label={`Ver perfil de ${b.name}`}>
      <img src={gallery[2]} alt={`${b.name} — galería 3`} width="320" height="200" loading="lazy" />
    </a>

    </div>

</div>
